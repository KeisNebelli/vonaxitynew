// vonaxity/backend/prisma/schema.prisma
// SQLite-compatible version (no enums, no String arrays)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles: CLIENT | NURSE | ADMIN
// UserStatus: ACTIVE | TRIAL | SUSPENDED | CANCELLED
// NurseStatus: PENDING | APPROVED | SUSPENDED
// VisitStatus: UNASSIGNED | PENDING | ACCEPTED | ON_THE_WAY | ARRIVED | IN_PROGRESS | COMPLETED | NO_SHOW | CANCELLED
// PaymentStatus: ACTIVE | TRIAL | PAST_DUE | CANCELLED | FAILED

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         String   @default("CLIENT")
  status       String   @default("TRIAL")
  country      String?
  city         String?
  language     String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nurseProfile  Nurse?
  subscription  Subscription?
  relatives     Relative[]
  payments      Payment[]
  notifications Notification[]
}

model Nurse {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  status            String   @default("PENDING")
  city              String   @default("")
  rating            Float    @default(0)
  totalVisits       Int      @default(0)
  totalEarnings     Float    @default(0)
  payRatePerVisit   Float    @default(20)
  availability      String   @default("[]")
  licenseNumber     String?
  issuingAuthority  String?
  bio               String?
  experience        String?
  languages         String   @default("[]")
  specialties       String   @default("[]")
  services          String   @default("[]")
  diplomaUrl        String?
  licenseUrl        String?
  profilePhotoUrl   String?
  paypalEmail       String?
  rejectionReason   String?
  submittedAt       DateTime?
  approvedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  visits       Visit[]
  reviews      Review[]
  payouts      Payout[]
  applications VisitApplication[]
}

model Relative {
  id           String   @id @default(cuid())
  clientId     String
  client       User     @relation(fields: [clientId], references: [id])
  name         String
  age          Int?
  phone        String?
  city         String
  address      String
  relationship String?
  healthNotes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  visits Visit[]
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  plan               String
  status             String    @default("TRIAL")
  stripeSubId        String?
  stripeCustomerId   String?
  visitsPerMonth     Int
  visitsUsed         Int       @default(0)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Visit {
  id              String    @id @default(cuid())
  workOrderNumber String?   @unique
  relativeId      String
  relative        Relative  @relation(fields: [relativeId], references: [id])
  nurseId         String?
  nurse           Nurse?    @relation(fields: [nurseId], references: [id])
  serviceType     String
  status          String    @default("UNASSIGNED")
  scheduledAt     DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  notes           String?
  bpSystolic  Int?
  bpDiastolic Int?
  heartRate   Int?
  glucose     Float?
  temperature Float?
  oxygenSat   Float?
  nurseNotes  String?
  reportSent  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  review       Review?
  applications VisitApplication[]
}

model VisitApplication {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id])
  nurseId   String
  nurse     Nurse    @relation(fields: [nurseId], references: [id])
  status    String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([visitId, nurseId])
}

model Review {
  id        String   @id @default(cuid())
  visitId   String   @unique
  visit     Visit    @relation(fields: [visitId], references: [id])
  nurseId   String
  nurse     Nurse    @relation(fields: [nurseId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  stripeId    String?
  amount      Float
  currency    String   @default("eur")
  status      String
  description String?
  createdAt   DateTime @default(now())
}

model Payout {
  id        String    @id @default(cuid())
  nurseId   String
  nurse     Nurse     @relation(fields: [nurseId], references: [id])
  amount    Float
  visits    Int
  period    String
  status    String    @default("pending")
  paidAt    DateTime?
  createdAt DateTime  @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  relatedId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}



model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

